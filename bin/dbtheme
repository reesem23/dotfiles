        B0=1a2f1a B1=ff7a85 B2=5ed4a4 B3=f0cb85 B4=66c6cc B5=d688ee B6=5ed4a4 B7=e0f0e0
        set_hypr_colors "4ec994cc" "1a2f1aaa"
        BAR_BG="rgba(10, 25, 10, 0.55)"
