    zenin)
        WP="$WALLPAPER_DIR/zenin.JPG"
        BG=060810 FG=c8cfe0
        R0=101520 R1=c05a5a R2=5a7890 R3=8a9ab0 R4=4a6880 R5=8a6888 R6=5a8898 R7=c8cfe0
        B0=182030 B1=d06a6a B2=6a88a0 B3=9aaac0 B4=5a7890 B5=9a7898 B6=6a98a8 B7=d8dff0
        set_hypr_colors "5a7890cc" "182030aa"
