        B0=1e3040 B1=f8b060 B2=70b8f0 B3=ffe070 B4=50a0e0 B5=9880d0 B6=60c8f8 B7=eef5ff
        set_hypr_colors "60a8e0cc" "1e3040aa"
        BAR_BG="rgba(10, 18, 30, 0.55)"
        BAR_BORDER="rgba(96, 168, 224, 0.65)"
        PEACLOCK_ACTIVE="#60a8e0"
        PEACLOCK_INACTIVE="#142030"
        ;;
    oilpaint)
        WP="$WALLPAPER_DIR/oilpaint.JPG"
        BG=0c0a06 FG=e8dcc8
        R0=1a1508 R1=c8603a R2=a09040 R3=d4a840 R4=886030 R5=b07050 R6=c09850 R7=e8dcc8
        B0=2a2010 B1=d8704a B2=b0a050 B3=e4b850 B4=987040 B5=c08060 B6=d0a860 B7=f0e8d8
