        exit 1
        ;;
esac

fi # end file-path / named-theme branch

write_foot
write_global_colors
write_ags_colors
write_wofi
write_peaclock
ags quit
sleep 0.3
ags run --gtk 3 ~/.config/ags/app.ts &
apply_wallpaper "$WP"
echo "Theme '$THEME' applied!"
