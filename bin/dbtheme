        ;;
    paint)
        WP="$WALLPAPER_DIR/paint.JPG"
        BG=060e0c FG=c8e8d8
        R0=0e1e18 R1=d06868 R2=40a888 R3=80c898 R4=308878 R5=7088a8 R6=40b8a8 R7=c8e8d8
        B0=182e28 B1=e07878 B2=50b898 B3=90d8a8 B4=409888 B5=8098b8 B6=50c8b8 B7=d8f0e8
        set_hypr_colors "40a888cc" "182e28aa"
