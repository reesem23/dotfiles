        PEACLOCK_INACTIVE="#1e1018"
        ;;
    b)
        WP="$WALLPAPER_DIR/b.JPG"
        BG=030810 FG=c0d8f0
        R0=0a1520 R1=4a8ac8 R2=5aaae0 R3=8ab8d8 R4=2a6aaa R5=6a9ac8 R6=7ab8e0 R7=c0d8f0
        B0=102030 B1=5a9ad8 B2=6abaf0 B3=9ac8e8 B4=3a7aba B5=7aaad8 B6=8ac8f0 B7=d0e8ff
        set_hypr_colors "5aaae0cc" "102030aa"
