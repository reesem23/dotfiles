        R0=1a1a2e R1=e05a6b R2=4a9eff R3=5bc4f5 R4=2087ff R5=7b6fff R6=40c4ff R7=c8d0e0
        B0=2a2a4a B1=ff6b7a B2=60aaff B3=70d4ff B4=4aa8ff B5=9d8fff B6=60d4ff B7=eef0f5
        set_hypr_colors "2087ffcc" "4c566aaa"
        BAR_BG="rgba(10, 20, 60, 0.55)"
        BAR_BORDER="rgba(32, 135, 255, 0.65)"
        PEACLOCK_ACTIVE="#2087ff"
