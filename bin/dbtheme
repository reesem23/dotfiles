        R0=1a2a1a R1=e06c75 R2=4ec994 R3=e5c07b R4=56b6c2 R5=c678dd R6=4ec994 R7=d0e8d0
        B0=2a3a2a B1=ff7a85 B2=5ed4a4 B3=f0cb85 B4=66c6cc B5=d688ee B6=5ed4a4 B7=e0f0e0
        set_hypr_colors "56b6c2cc" "2a3a2aaa"
        BAR_BG="rgba(13, 25, 20, 0.55)"
        BAR_BORDER="rgba(86, 182, 194, 0.65)"
