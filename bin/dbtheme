        PEACLOCK_INACTIVE="#1a2a1a"
        ;;
    lain)
        WP="$WALLPAPER_DIR/lain.jpg"
        BG=050508 FG=c8ccd8
        R0=0f0f18 R1=c45a8a R2=5a7acc R3=8a9ab8 R4=4a6aaa R5=8a5a9a R6=5a8aaa R7=c8ccd8
        B0=1a1a28 B1=d46a9a B2=6a8adc B3=9aaac8 B4=5a7aba B5=9a6aaa B6=6a9aba B7=d8dce8
        set_hypr_colors "5a7acccc" "1a1a28aa"
        BAR_BG="rgba(10, 10, 30, 0.55)"
        BAR_BORDER="rgba(90, 122, 204, 0.65)"
        PEACLOCK_ACTIVE="#5a7acc"
        PEACLOCK_INACTIVE="#0f0f18"
        ;;
    omarchy)
        WP="$WALLPAPER_DIR/omarchy.jpg"
        BG=0c0c0c FG=d4d4d4
        R0=1c1c1c R1=cc6666 R2=666666 R3=b5b5b5 R4=888888 R5=999999 R6=aaaaaa R7=d4d4d4
        B0=2a2a2a B1=dd7777 B2=777777 B3=c5c5c5 B4=999999 B5=aaaaaa B6=bbbbbb B7=e4e4e4
        set_hypr_colors "888888cc" "333333aa"
        BAR_BG="rgba(20, 20, 20, 0.55)"
        BAR_BORDER="rgba(136, 136, 136, 0.65)"
        PEACLOCK_ACTIVE="#888888"
        PEACLOCK_INACTIVE="#1c1c1c"
        ;;
    arizona)
        WP="$WALLPAPER_DIR/arizona.JPG"
        BG=0f0a0e FG=e8d5c8
        R0=1e1018 R1=c45a6a R2=a06878 R3=d4956a R4=8a5a7a R5=b87a8a R6=c4856a R7=e8d5c8
        B0=2e1828 B1=d46a7a B2=b07888 B3=e4a57a B4=9a6a8a B5=c88a9a B6=d4957a B7=f0e0d5
        set_hypr_colors "c45a6acc" "2e1828aa"
        BAR_BG="rgba(30, 10, 20, 0.55)"
