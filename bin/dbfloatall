#!/usr/bin/env bash

# Float all windows if any are tiled; tile all if everything is already floating
# Only affects windows on the currently focused workspace
active_ws=$(hyprctl activeworkspace -j | jq '.id')

any_tiled=$(hyprctl clients -j | jq --argjson ws "$active_ws" '[.[] | select(.workspace.id == $ws and .floating == false)] | length')

if [ "$any_tiled" -gt 0 ]; then
    hyprctl clients -j | jq --argjson ws "$active_ws" -r '.[] | select(.workspace.id == $ws and .floating == false) | .address' | while read -r addr; do
        [ -z "$addr" ] && continue
        hyprctl dispatch togglefloating "address:$addr"
    done
else
    hyprctl clients -j | jq --argjson ws "$active_ws" -r '.[] | select(.workspace.id == $ws and .floating == true) | .address' | while read -r addr; do
        [ -z "$addr" ] && continue
        hyprctl dispatch togglefloating "address:$addr"
    done
fi
